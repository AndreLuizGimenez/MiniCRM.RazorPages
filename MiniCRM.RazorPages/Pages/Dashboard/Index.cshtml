@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 page-title mb-1">Dashboard</h1>
        <p class="text-muted mb-0">Resumo dos clientes e últimos atendimentos registrados.</p>
    </div>
    <a asp-page="/Customers/Create" class="btn btn-primary">Novo cliente</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Total de clientes</div>
                <div class="display-6 fw-semibold">@Model.TotalClientes</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Novos</div>
                <div class="display-6 fw-semibold text-primary">@Model.TotalNovos</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Em negociação</div>
                <div class="display-6 fw-semibold text-warning">@Model.TotalEmNegociacao</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Fechados</div>
                <div class="display-6 fw-semibold text-success">@Model.TotalFechados</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Perdidos</div>
                <div class="display-6 fw-semibold text-danger">@Model.TotalPerdidos</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0">Últimos atendimentos</h2>
        <a asp-page="/Customers/Index" class="btn btn-outline-primary btn-sm">Ver clientes</a>
    </div>
    <div class="card-body p-0">
        @if (Model.UltimosAtendimentos.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Cliente</th>
                            <th>Tipo</th>
                            <th>Data</th>
                            <th>Próximo passo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var atendimento in Model.UltimosAtendimentos)
                        {
                            <tr>
                                <td>
                                    <a asp-page="/Customers/Details" asp-route-id="@atendimento.ClienteId" class="fw-semibold text-decoration-none">
                                        @atendimento.Cliente?.Nome
                                    </a>
                                </td>
                                <td>@FormatAttendanceType(atendimento.TipoAtendimento)</td>
                                <td>@atendimento.DataAtendimento.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(string.IsNullOrWhiteSpace(atendimento.ProximoPasso) ? "-" : atendimento.ProximoPasso)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-4 text-center text-muted">
                Nenhum atendimento registrado ainda.
            </div>
        }
    </div>
</div>

@functions {
    private static string FormatAttendanceType(AttendanceType type) => type switch
    {
        AttendanceType.Ligacao => "Ligação",
        AttendanceType.Email => "E-mail",
        AttendanceType.Reuniao => "Reunião",
        _ => "WhatsApp"
    };
}
