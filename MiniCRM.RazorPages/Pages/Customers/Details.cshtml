@page "{id:int}"
@model DetailsModel
@{
    ViewData["Title"] = "Detalhes do cliente";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 page-title mb-1">@Model.Customer.Nome</h1>
        <p class="text-muted mb-0">Detalhes do cliente e atendimentos vinculados.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="./Edit" asp-route-id="@Model.Customer.Id" class="btn btn-outline-primary">Editar</a>
        <a asp-page="/Attendances/Create" asp-route-customerId="@Model.Customer.Id" class="btn btn-primary">Novo atendimento</a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">Dados do cliente</h2>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">E-mail</dt>
                    <dd class="col-sm-8">@Model.Customer.Email</dd>

                    <dt class="col-sm-4">Telefone</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Customer.Telefone) ? "-" : Model.Customer.Telefone)</dd>

                    <dt class="col-sm-4">Documento</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Customer.Documento) ? "-" : Model.Customer.Documento)</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge status-badge @GetStatusCssClass(Model.Customer.Status)">
                            @FormatStatus(Model.Customer.Status)
                        </span>
                    </dd>

                    <dt class="col-sm-4">Cadastro</dt>
                    <dd class="col-sm-8">@Model.Customer.DataCadastro.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h2 class="h5 mb-0">Atendimentos</h2>
                <a asp-page="/Attendances/Index" asp-route-customerId="@Model.Customer.Id" class="btn btn-outline-primary btn-sm">Ver todos</a>
            </div>
            <div class="card-body p-0">
                @if (Model.Customer.Atendimentos.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tipo</th>
                                    <th>Data</th>
                                    <th>Próximo passo</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var atendimento in Model.Customer.Atendimentos.OrderByDescending(attendance => attendance.DataAtendimento))
                                {
                                    <tr>
                                        <td>@FormatAttendanceType(atendimento.TipoAtendimento)</td>
                                        <td>@atendimento.DataAtendimento.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@(string.IsNullOrWhiteSpace(atendimento.ProximoPasso) ? "-" : atendimento.ProximoPasso)</td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm" role="group" aria-label="Ações do atendimento">
                                                <a asp-page="/Attendances/Edit" asp-route-id="@atendimento.Id" class="btn btn-outline-primary">Editar</a>
                                                <a asp-page="/Attendances/Delete" asp-route-id="@atendimento.Id" class="btn btn-outline-danger">Excluir</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        Nenhum atendimento registrado para este cliente.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<a asp-page="./Index" class="btn btn-outline-secondary">Voltar para clientes</a>

@functions {
    private static string FormatStatus(CustomerStatus status) => status switch
    {
        CustomerStatus.EmNegociacao => "Em negociação",
        CustomerStatus.Fechado => "Fechado",
        CustomerStatus.Perdido => "Perdido",
        _ => "Novo"
    };

    private static string GetStatusCssClass(CustomerStatus status) => status switch
    {
        CustomerStatus.EmNegociacao => "text-bg-warning",
        CustomerStatus.Fechado => "text-bg-success",
        CustomerStatus.Perdido => "text-bg-danger",
        _ => "text-bg-primary"
    };

    private static string FormatAttendanceType(AttendanceType type) => type switch
    {
        AttendanceType.Ligacao => "Ligação",
        AttendanceType.Email => "E-mail",
        AttendanceType.Reuniao => "Reunião",
        _ => "WhatsApp"
    };
}
