@page "{id:int}"
@model DeleteModel
@{
    ViewData["Title"] = "Excluir cliente";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-danger">
            <div class="card-body p-4">
                <h1 class="h3 page-title mb-3">Excluir cliente</h1>
                <p class="mb-4">
                    Confirme a exclusão do cliente <strong>@Model.Customer.Nome</strong>.
                    Os atendimentos vinculados a ele também serão removidos.
                </p>

                <dl class="row">
                    <dt class="col-sm-3">E-mail</dt>
                    <dd class="col-sm-9">@Model.Customer.Email</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">@FormatStatus(Model.Customer.Status)</dd>
                </dl>

                <form method="post">
                    <input type="hidden" asp-for="Customer.Id" />
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-page="./Details" asp-route-id="@Model.Customer.Id" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-danger">Excluir cliente</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@functions {
    private static string FormatStatus(CustomerStatus status) => status switch
    {
        CustomerStatus.EmNegociacao => "Em negociação",
        CustomerStatus.Fechado => "Fechado",
        CustomerStatus.Perdido => "Perdido",
        _ => "Novo"
    };
}
