@page
@model IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 page-title mb-1">Clientes</h1>
        <p class="text-muted mb-0">Cadastro e acompanhamento dos clientes comerciais.</p>
    </div>
    <a asp-page="./Create" class="btn btn-primary">Novo cliente</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2">
            <div class="col-md-9">
                <label asp-for="SearchTerm" class="form-label visually-hidden">Buscar cliente</label>
                <input asp-for="SearchTerm" class="form-control" placeholder="Buscar por nome ou e-mail" />
            </div>
            <div class="col-md-3 d-grid">
                <button type="submit" class="btn btn-outline-primary">Buscar</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Customers.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nome</th>
                            <th>E-mail</th>
                            <th>Telefone</th>
                            <th>Status</th>
                            <th>Cadastro</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model.Customers)
                        {
                            <tr>
                                <td class="fw-semibold">@customer.Nome</td>
                                <td>@customer.Email</td>
                                <td>@(string.IsNullOrWhiteSpace(customer.Telefone) ? "-" : customer.Telefone)</td>
                                <td>
                                    <span class="badge status-badge @GetStatusCssClass(customer.Status)">
                                        @FormatStatus(customer.Status)
                                    </span>
                                </td>
                                <td>@customer.DataCadastro.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm" role="group" aria-label="Ações do cliente">
                                        <a asp-page="./Details" asp-route-id="@customer.Id" class="btn btn-outline-secondary">Detalhes</a>
                                        <a asp-page="./Edit" asp-route-id="@customer.Id" class="btn btn-outline-primary">Editar</a>
                                        <a asp-page="./Delete" asp-route-id="@customer.Id" class="btn btn-outline-danger">Excluir</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-4 text-center text-muted">
                Nenhum cliente encontrado.
            </div>
        }
    </div>
</div>

@functions {
    private static string FormatStatus(CustomerStatus status) => status switch
    {
        CustomerStatus.EmNegociacao => "Em negociação",
        CustomerStatus.Fechado => "Fechado",
        CustomerStatus.Perdido => "Perdido",
        _ => "Novo"
    };

    private static string GetStatusCssClass(CustomerStatus status) => status switch
    {
        CustomerStatus.EmNegociacao => "text-bg-warning",
        CustomerStatus.Fechado => "text-bg-success",
        CustomerStatus.Perdido => "text-bg-danger",
        _ => "text-bg-primary"
    };
}
