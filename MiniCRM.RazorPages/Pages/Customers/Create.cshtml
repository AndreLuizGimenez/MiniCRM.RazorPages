@page
@model CreateModel
@{
    ViewData["Title"] = "Novo cliente";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 page-title mb-1">Novo cliente</h1>
        <p class="text-muted mb-0">Preencha os dados principais do cliente.</p>
    </div>
    <a asp-page="./Index" class="btn btn-outline-secondary">Voltar</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Customer.Nome" class="form-label"></label>
                    <input asp-for="Customer.Nome" class="form-control" />
                    <span asp-validation-for="Customer.Nome" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Customer.Email" class="form-label"></label>
                    <input asp-for="Customer.Email" class="form-control" />
                    <span asp-validation-for="Customer.Email" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Customer.Telefone" class="form-label"></label>
                    <input asp-for="Customer.Telefone" class="form-control" />
                    <span asp-validation-for="Customer.Telefone" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Customer.Documento" class="form-label"></label>
                    <input asp-for="Customer.Documento" class="form-control" />
                    <span asp-validation-for="Customer.Documento" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Customer.Status" class="form-label"></label>
                    <select asp-for="Customer.Status" asp-items="Html.GetEnumSelectList<CustomerStatus>()" class="form-select"></select>
                    <span asp-validation-for="Customer.Status" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary">Salvar cliente</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
