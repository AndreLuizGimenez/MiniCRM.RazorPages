@page "{customerId:int}"
@model IndexModel
@{
    ViewData["Title"] = "Atendimentos";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 page-title mb-1">Atendimentos de @Model.Customer.Nome</h1>
        <p class="text-muted mb-0">Histórico de contatos comerciais do cliente.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Customers/Details" asp-route-id="@Model.Customer.Id" class="btn btn-outline-secondary">Voltar</a>
        <a asp-page="./Create" asp-route-customerId="@Model.Customer.Id" class="btn btn-primary">Novo atendimento</a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Customer.Atendimentos.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tipo</th>
                            <th>Data</th>
                            <th>Observação</th>
                            <th>Próximo passo</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var attendance in Model.Customer.Atendimentos.OrderByDescending(attendance => attendance.DataAtendimento))
                        {
                            <tr>
                                <td>@FormatAttendanceType(attendance.TipoAtendimento)</td>
                                <td>@attendance.DataAtendimento.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@attendance.Observacao</td>
                                <td>@(string.IsNullOrWhiteSpace(attendance.ProximoPasso) ? "-" : attendance.ProximoPasso)</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm" role="group" aria-label="Ações do atendimento">
                                        <a asp-page="./Edit" asp-route-id="@attendance.Id" class="btn btn-outline-primary">Editar</a>
                                        <a asp-page="./Delete" asp-route-id="@attendance.Id" class="btn btn-outline-danger">Excluir</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-4 text-center text-muted">
                Nenhum atendimento registrado para este cliente.
            </div>
        }
    </div>
</div>

@functions {
    private static string FormatAttendanceType(AttendanceType type) => type switch
    {
        AttendanceType.Ligacao => "Ligação",
        AttendanceType.Email => "E-mail",
        AttendanceType.Reuniao => "Reunião",
        _ => "WhatsApp"
    };
}
